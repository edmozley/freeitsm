# FreeITSM - Git Ignore File
# Prevents sensitive and unnecessary files from being pushed to GitHub

# ============================================
# SENSITIVE FILES - NEVER COMMIT THESE
# ============================================

# Database backups and dumps (but allow schema files)
*.bak
*backup*.sql
*dump*.sql
database/backups/

# Encryption keys
*.key

# Environment files
.env
.env.local
.env.*.local

# ============================================
# DEVELOPMENT & IDE FILES
# ============================================

# Claude Code settings
.claude/
CLAUDE.local.md
CHANGELOG.local.md

# Design docs not yet ready to publish
docs/design/

# Visual Studio Code
.vscode/
*.code-workspace

# PhpStorm / IntelliJ IDEA
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# ============================================
# OPERATING SYSTEM FILES
# ============================================

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Linux
*~
.directory

# ============================================
# PHP & COMPOSER
# ============================================

# Composer dependencies (if you add them later)
/vendor/

# PHP error logs
error_log
php_errors.log

# ============================================
# LOGS & TEMPORARY FILES
# ============================================

# Log files
*.log
logs/
!reporting/logs/

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~
.cache/
tmp/
temp/

# Upload directories (may contain sensitive user data)
uploads/*
!uploads/.gitkeep

# Module-specific runtime content (attachments, uploaded LMS courses, etc.)
# These are populated by the running app and are tenant-specific — never commit.
change-management/attachments/
# Ignore uploaded course content, but DO ship the guard that stops that
# directory ever executing code. Ignoring the CONTENTS (/*) rather than the
# directory itself is what lets the negation work — git won't re-include a file
# whose parent directory is ignored.
lms/content/*
!lms/content/.htaccess
tickets/attachments/
contracts/rfp-builder/uploads/*
!contracts/rfp-builder/uploads/.htaccess
system/uploads/branding/
recordings/*
!recordings/.htaccess

# ============================================
# NODE MODULES (if you use npm/Node.js)
# ============================================

node_modules/
npm-debug.log
yarn-error.log

# ============================================
# BACKUP FILES
# ============================================

*.backup
*.old
*.orig
